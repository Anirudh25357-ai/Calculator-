<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Calculator</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0d0d1a 0%, #111827 60%, #0a1628 100%);
      font-family: 'Inter', sans-serif;
      padding: 20px;
    }

    .calculator {
      width: 320px;
      background: #1c1c1e;
      border-radius: 28px;
      overflow: hidden;
      box-shadow:
        0 40px 80px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.07),
        inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .display {
      padding: 28px 24px 16px;
      min-height: 120px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: flex-end;
    }

    .expression {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.35);
      letter-spacing: 0.04em;
      min-height: 18px;
      margin-bottom: 6px;
      word-break: break-all;
      text-align: right;
    }

    .result {
      font-size: 3.2rem;
      font-weight: 300;
      color: #ffffff;
      letter-spacing: -0.02em;
      line-height: 1;
      word-break: break-all;
      text-align: right;
      transition: font-size 0.12s ease;
    }

    .result.shrink  { font-size: 2.2rem; }
    .result.xshrink { font-size: 1.6rem; }

    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      padding: 10px 16px 22px;
    }

    button {
      height: 70px;
      border: none;
      border-radius: 50px;
      font-family: 'Inter', sans-serif;
      font-size: 1.3rem;
      font-weight: 400;
      cursor: pointer;
      outline: none;
      transition: transform 0.08s ease, filter 0.08s ease, background 0.15s ease;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    button:active { transform: scale(0.92); filter: brightness(0.85); }

    .btn-num    { background: #2c2c2e; color: #ffffff; box-shadow: 0 2px 8px rgba(0,0,0,0.35); }
    .btn-num:hover { background: #3a3a3c; }

    .btn-action { background: #5a5a5e; color: #ffffff; font-weight: 500; box-shadow: 0 2px 8px rgba(0,0,0,0.35); }
    .btn-action:hover { background: #6e6e72; }

    .btn-op     { background: #e67e22; color: #ffffff; font-size: 1.5rem; box-shadow: 0 4px 18px rgba(230,126,34,0.35); }
    .btn-op:hover { background: #f39c12; }
    .btn-op.active-op { background: #ffffff; color: #e67e22; }

    .btn-eq     { background: #e67e22; color: #ffffff; font-size: 1.5rem; box-shadow: 0 4px 18px rgba(230,126,34,0.35); }
    .btn-eq:hover { background: #f39c12; }

    .btn-zero   { grid-column: span 2; text-align: left; padding-left: 26px; }

    .footer {
      text-align: center;
      padding-bottom: 14px;
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.15);
      letter-spacing: 0.1em;
    }
  </style>
</head>
<body>

<div class="calculator">
  <div class="display">
    <div class="expression" id="expression"></div>
    <div class="result"     id="result">0</div>
  </div>

  <div class="buttons">
    <button class="btn-action" data-action="clear">AC</button>
    <button class="btn-action" data-action="negate">+/−</button>
    <button class="btn-action" data-action="percent">%</button>
    <button class="btn-op"     data-op="/">÷</button>

    <button class="btn-num" data-num="7">7</button>
    <button class="btn-num" data-num="8">8</button>
    <button class="btn-num" data-num="9">9</button>
    <button class="btn-op"  data-op="*">×</button>

    <button class="btn-num" data-num="4">4</button>
    <button class="btn-num" data-num="5">5</button>
    <button class="btn-num" data-num="6">6</button>
    <button class="btn-op"  data-op="-">−</button>

    <button class="btn-num" data-num="1">1</button>
    <button class="btn-num" data-num="2">2</button>
    <button class="btn-num" data-num="3">3</button>
    <button class="btn-op"  data-op="+">+</button>

    <button class="btn-num btn-zero" data-num="0">0</button>
    <button class="btn-num"          data-num=".">.</button>
    <button class="btn-eq"           data-action="equals">=</button>
  </div>

  <div class="footer">KEYBOARD SUPPORTED · ESC TO CLEAR</div>
</div>

<script>
  let display      = '0';
  let prev         = null;
  let operator     = null;
  let waitingForOp = false;
  let justCalc     = false;
  let expression   = '';
  let activeOp     = null;

  const resultEl     = document.getElementById('result');
  const expressionEl = document.getElementById('expression');
  const OP_SYMBOL    = { '/': '÷', '*': '×', '-': '−', '+': '+' };

  function calculate(a, op, b) {
    const x = parseFloat(a), y = parseFloat(b);
    if (op === '+') return x + y;
    if (op === '-') return x - y;
    if (op === '*') return x * y;
    if (op === '/') return y === 0 ? 'Error' : x / y;
    return b;
  }

  function formatNum(val) {
    if (val === 'Error') return 'Error';
    const n = parseFloat(val);
    if (isNaN(n)) return val;
    if (Math.abs(n) >= 1e10 || (Math.abs(n) < 1e-6 && n !== 0))
      return n.toExponential(4);
    const s = String(val);
    if (s.endsWith('.') || /\.\d*0+$/.test(s)) return s;
    return parseFloat(n.toPrecision(10)).toString();
  }

  function updateDisplay() {
    resultEl.textContent     = display;
    expressionEl.textContent = expression;
    const len = display.length;
    resultEl.classList.remove('shrink', 'xshrink');
    if (len > 12) resultEl.classList.add('xshrink');
    else if (len > 8) resultEl.classList.add('shrink');
    document.querySelectorAll('.btn-op').forEach(btn => {
      btn.classList.remove('active-op');
      if (btn.dataset.op === activeOp && waitingForOp)
        btn.classList.add('active-op');
    });
  }

  function inputNumber(val) {
    if (waitingForOp) {
      display = val === '.' ? '0.' : val;
      waitingForOp = false; justCalc = false;
    } else if (justCalc) {
      display = val === '.' ? '0.' : val;
      justCalc = false; prev = null; operator = null; expression = ''; activeOp = null;
    } else {
      if (val === '.' && display.includes('.')) return;
      if (display.replace('.','').replace('-','').length >= 12) return;
      display = (display === '0' && val !== '.') ? val : display + val;
    }
    updateDisplay();
  }

  function inputOperator(op) {
    activeOp = op;
    if (prev !== null && operator && !waitingForOp) {
      const res = calculate(prev, operator, display);
      display = formatNum(res.toString());
      prev = res.toString();
    } else {
      prev = display;
    }
    expression   = formatNum(prev) + ' ' + OP_SYMBOL[op];
    operator     = op;
    waitingForOp = true;
    justCalc     = false;
    updateDisplay();
  }

  function inputEquals() {
    if (prev === null || operator === null) return;
    const cur = display;
    const res = calculate(prev, operator, cur);
    expression   = `${formatNum(prev)} ${OP_SYMBOL[operator]} ${formatNum(cur)} =`;
    display      = formatNum(res.toString());
    prev = null; operator = null; activeOp = null;
    waitingForOp = false; justCalc = true;
    updateDisplay();
  }

  function inputAction(action) {
    if (action === 'clear') {
      display = '0'; prev = null; operator = null;
      waitingForOp = false; justCalc = false; expression = ''; activeOp = null;
    } else if (action === 'negate') {
      if (display !== '0') display = (parseFloat(display) * -1).toString();
    } else if (action === 'percent') {
      display = (parseFloat(display) / 100).toString();
    }
    updateDisplay();
  }

  document.querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
      if (btn.dataset.num   !== undefined)             inputNumber(btn.dataset.num);
      if (btn.dataset.op    !== undefined)             inputOperator(btn.dataset.op);
      if (btn.dataset.action === 'equals')             inputEquals();
      if (['clear','negate','percent'].includes(btn.dataset.action)) inputAction(btn.dataset.action);
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key >= '0' && e.key <= '9')        inputNumber(e.key);
    else if (e.key === '.')                  inputNumber('.');
    else if (e.key === '+')                  inputOperator('+');
    else if (e.key === '-')                  inputOperator('-');
    else if (e.key === '*')                  inputOperator('*');
    else if (e.key === '/') { e.preventDefault(); inputOperator('/'); }
    else if (e.key === 'Enter' || e.key === '=') inputEquals();
    else if (e.key === 'Escape')             inputAction('clear');
    else if (e.key === '%')                  inputAction('percent');
    else if (e.key === 'Backspace') {
      display = display.length > 1 ? display.slice(0, -1) : '0';
      updateDisplay();
    }
  });

  updateDisplay();
</script>
</body>
</html>
